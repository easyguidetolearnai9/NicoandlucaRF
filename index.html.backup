          <button class="submit-btn success" onclick="submitCatch()">🐟 Post Catch</button>
        </div>
      </div>
    </div>

    <div class="charter-panel" id="panel-profile">
      <div class="charter-form">
        <h3 id="profileFormTitle">🚤 Charter Profile</h3>
        <p style="text-align:center;font-size:0.78rem;color:var(--text-secondary);margin-bottom:14px">Set up your charter profile</p>
        <div class="form-group">
          <label>🏢 Charter Name</label>
          <input type="text" id="charterName" placeholder="e.g. Blue Water Charters">
        </div>
        <div class="form-group">
          <label>👨‍✈️ Captain Name</label>
          <input type="text" id="captainName" placeholder="e.g. Captain Mike">
        </div>
        <div class="form-group">
          <label>🚤 Boat Name</label>
          <input type="text" id="boatName" placeholder="e.g. The Reel Deal">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>📞 Phone</label>
            <input type="tel" id="charterPhone" placeholder="(305) 555-1234">
          </div>
          <div class="form-group">
            <label>📧 Email</label>
            <input type="email" id="charterEmail" placeholder="captain@charter.com">
          </div>
        </div>
        <div class="form-group">
          <label>🌐 Website (optional)</label>
          <input type="url" id="charterWebsite" placeholder="https://yourcharter.com">
        </div>
        <div class="form-group">
          <label>📝 About</label>
          <textarea id="charterBio" placeholder="Tell customers about your charter..."></textarea>
        </div>
        <div class="form-group">
          <label>🐟 Fresh Fish Available Today?</label>
          <div class="fish-toggle" id="fishToggleWrap" onclick="toggleFishAvailable()">
            <div class="fish-toggle-track" id="fishToggleTrack">
              <div class="fish-toggle-thumb" id="fishToggleThumb"></div>
            </div>
            <span class="fish-toggle-label" id="fishToggleLabel">No</span>
          </div>
        </div>
        <button class="submit-btn" id="profileSaveBtn" onclick="saveCharterProfile()">🚤 Save Profile</button>
        <button class="submit-btn danger" id="profileDeleteBtn" style="display:none;margin-top:8px" onclick="deleteCharterProfile()">🗑️ Delete Profile</button>
      </div>
    </div>
  </div>

  <div class="tip" id="tip" style="display:none"><strong>Pro Tip:</strong> <span id="tipText"></span></div>
  <div id="lastUpdated" style="text-align:center;font-size:0.75rem;color:var(--text-tertiary);margin-top:18px">Loading conditions...</div>
  <button class="refresh-btn" onclick="fetchForecast()">🔄 Refresh Conditions</button>
  <div class="footer">
    <strong>Powered by 10 real-time data sources</strong><br>
    NOAA · Open-Meteo · Solunar Theory<br>
    Wave, tide, weather, and water temp analysis for Key Biscayne, FL 33149
  </div>
</div>

<script>
// ===============================================
// CORE CONSTANTS
// ===============================================
const TIDE_STATION = '8723214'; // Virginia Key
const LAT = 25.69;
const LON = -80.16;

// API URLs
const MARINE_API = `https://marine-api.open-meteo.com/v1/marine?latitude=${LAT}&longitude=${LON}&daily=wave_height_max,wave_period_max,wind_wave_height_max&current=wave_height,wave_period,wind_wave_height&timezone=America%2FNew_York&forecast_days=7`;
const WEATHER_API = `https://api.open-meteo.com/v1/forecast?latitude=${LAT}&longitude=${LON}&current=wind_speed_10m,wind_direction_10m,wind_gusts_10m,cloud_cover,precipitation,pressure_msl&hourly=pressure_msl,cloud_cover,precipitation_probability,uv_index&daily=sunrise,sunset&timezone=America/New_York&forecast_days=2`;
const WATER_TEMP_API = `https://api.tidesandcurrents.noaa.gov/api/prod/datagetter?date=latest&station=${TIDE_STATION}&product=water_temperature&units=english&time_zone=lst_ldt&format=json`;

// ---- Toast ----
function showToast(msg, duration=2500){
  const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),duration);
}

// ---- Tips ----
const tips=["Calm water = better visibility. Fish can see your bait more clearly.","Dawn and dusk feeding windows yield the best results.","Flat conditions favor near-structure fishing — reefs, rocks, wrecks.","Monitor barometric pressure. Falling pressure often triggers aggressive feeding.","Full moon nights drive stronger tides — fish feed more during peak flow.","High tide brings fish inshore. Target flats and mangrove edges.","New moon and full moon create spring tides — plan trips accordingly.","Falling pressure before storms = feeding frenzy. Fish sense weather changes.","Cloud cover 60-90% optimal — reduces surface glare, fish less cautious.","Solunar major periods (moon overhead/underfoot) drive peak activity."];

// ===============================================
// MOON PHASE CALCULATION
// ===============================================
function getMoonPhase(date) {
  const year = date.getFullYear();
  const month = date.getMonth() + 1;
  const day = date.getDate();

  let c = 0, e = 0;
  if (month < 3) {
    c = year - 1;
    e = month + 12;
  } else {
    c = year;
    e = month;
  }

  const jd = Math.floor(365.25 * (c + 4716)) + Math.floor(30.6001 * (e + 1)) + day - 1524.5;
  const daysSinceNew = jd - 2451549.5;
  const synodicMonth = 29.53058770576;
  let phase = daysSinceNew % synodicMonth;
  if (phase < 0) phase += synodicMonth;

  return {
    age: phase,
    fraction: phase / synodicMonth,
    isFullMoon: phase >= 13.5 && phase <= 16,
    isNewMoon: phase <= 1.5 || phase >= 28,
    phaseName: getMoonPhaseName(phase),
    emoji: getMoonEmoji(phase)
  };
}

function getMoonPhaseName(age) {
  if (age <= 1.5 || age >= 28) return 'New Moon';
  if (age < 7.4) return 'Waxing Crescent';
  if (age < 8.4) return 'First Quarter';
  if (age < 13.5) return 'Waxing Gibbous';
  if (age < 16) return 'Full Moon';
  if (age < 22) return 'Waning Gibbous';
  if (age < 23) return 'Last Quarter';
  return 'Waning Crescent';
}

function getMoonEmoji(age) {
  if (age <= 1.5 || age >= 28) return '🌑';
  if (age < 7.4) return '🌒';
  if (age < 8.4) return '🌓';
  if (age < 13.5) return '🌔';
  if (age < 16) return '🌕';
  if (age < 22) return '🌖';
  if (age < 23) return '🌗';
  return '🌘';
}

function updateMoonPhase() {
  const moon = getMoonPhase(new Date());
  document.getElementById('moonIcon').textContent = moon.emoji;
  document.getElementById('moonValue').textContent = moon.phaseName;

  const box = document.getElementById('moonBox');
  if (moon.isFullMoon) {
    box.classList.add('full-moon');
    document.getElementById('moonLabel').textContent = '🌕 Full Moon';
  } else if (moon.isNewMoon) {
    box.classList.add('full-moon');
    document.getElementById('moonLabel').textContent = '🌑 New Moon';
  } else {
    document.getElementById('moonLabel').textContent = 'Moon Phase';
  }

  const moonBanner = document.getElementById('moonBanner');
  const moonBannerEmoji = document.getElementById('moonBannerEmoji');
  const moonBannerStatus = document.getElementById('moonBannerStatus');
  const moonBannerDetail = document.getElementById('moonBannerDetail');

  if (moon.isFullMoon) {
    moonBanner.className = 'indicator-banner moon-yes';
    moonBannerEmoji.textContent = '🌕';
    moonBannerStatus.innerHTML = '<span class="pulse-dot"></span>Full Moon';
    moonBannerDetail.textContent = 'Prime solunar activity — peak feeding conditions';
  } else {
    moonBanner.className = 'indicator-banner moon-no';
    moonBannerEmoji.textContent = moon.emoji;
    moonBannerStatus.textContent = moon.phaseName;
    const daysUntilFull = moon.age < 14.75 ? (14.75 - moon.age).toFixed(0) : (29.53 - moon.age + 14.75).toFixed(0);
    moonBannerDetail.textContent = 'Full moon in ~' + daysUntilFull + ' days';
  }
  document.getElementById('indicatorBanners').style.display = 'grid';
}

// ===============================================
// SOLUNAR FEEDING TIMES
// ===============================================
function getSolunarTimes(date) {
  const moon = getMoonPhase(date);
  const age = moon.age;

  const baseSunrise = 6.5;
  let moonriseHour = baseSunrise + (age * (50/60));
  moonriseHour = moonriseHour % 24;

  let moonsetHour = (moonriseHour + 12.4) % 24;
  let transitHour = (moonriseHour + 6.2) % 24;
  let underfootHour = (transitHour + 12.2) % 24;

  const nearFullOrNew = Math.min(
    Math.abs(age - 0),
    Math.abs(age - 29.53),
    Math.abs(age - 14.76)
  );
  const strength = 1.0 - (nearFullOrNew / 14.76) * 0.5;

  const periods = [
    { type: 'major', label: '🌟 Moon Over', hour: transitHour, duration: 2 },
    { type: 'major', label: '🌟 Moon Under', hour: underfootHour, duration: 2 },
    { type: 'minor', label: '🌙 Moonrise', hour: moonriseHour, duration: 1 },
    { type: 'minor', label: '🌙 Moonset', hour: moonsetHour, duration: 1 }
  ];

  periods.sort((a, b) => a.hour - b.hour);

  return { periods, strength, moon };
}

function formatHour(h) {
  h = ((h % 24) + 24) % 24;
  const hr = Math.floor(h);
  const min = Math.round((h - hr) * 60);
  const ampm = hr >= 12 ? 'PM' : 'AM';
  const hr12 = hr === 0 ? 12 : hr > 12 ? hr - 12 : hr;
  return `${hr12}:${String(min).padStart(2,'0')} ${ampm}`;
}

function isInPeriod(currentHour, periodHour, duration) {
  const halfDur = duration / 2;
  const start = ((periodHour - halfDur) % 24 + 24) % 24;
  const end = ((periodHour + halfDur) % 24 + 24) % 24;
  if (start < end) {
    return currentHour >= start && currentHour <= end;
  } else {
    return currentHour >= start || currentHour <= end;
  }
}

// ===============================================
// 10-FACTOR PRIME SCORE CALCULATION
// ===============================================

// Factor 1: Wave Height (/12)
function scoreWaveHeight(waveFeet) {
  if (waveFeet <= 1) return 12;
  if (waveFeet <= 2) return 10;
  if (waveFeet <= 3) return 7;
  if (waveFeet <= 4) return 4;
  return 1;
}

// Factor 2: Wind Speed & Direction (/14)
function scoreWind(speedMph, directionDeg) {
  let baseScore = 0;
  if (speedMph <= 8) baseScore = 10;
  else if (speedMph <= 12) baseScore = 8;
  else if (speedMph <= 18) baseScore = 5;
  else if (speedMph <= 25) baseScore = 2;
  else baseScore = 0;

  // Direction bonus/penalty
  let dirBonus = 0;
  if (directionDeg >= 225 && directionDeg <= 315) dirBonus = 4; // W, NW, SW (offshore)
  else if ((directionDeg >= 315 || directionDeg <= 45) || (directionDeg >= 135 && directionDeg <= 225)) dirBonus = 1; // N, S (cross)
  else dirBonus = -2; // E, NE, SE (onshore)

  return Math.max(0, Math.min(14, baseScore + dirBonus));
}

// Factor 3: Barometric Pressure Trend (/14)
function scorePressureTrend(currentPressure, hourlyPressures) {
  if (!hourlyPressures || hourlyPressures.length < 4) return 10; // default neutral

  const idx3h = Math.min(3, hourlyPressures.length - 1);
  const pressure3hAgo = hourlyPressures[idx3h];
  const trend = currentPressure - pressure3hAgo;

  if (trend <= -2) return 14; // rapidly falling
  if (trend <= -1) return 12; // slowly falling
  if (Math.abs(trend) <= 1) {
    if (currentPressure > 1025) return 8; // very high + stable
    return 10; // stable
  }
  if (trend <= 2) return 6; // slowly rising
  return 3; // rapidly rising
}

// Factor 4: Solunar Activity (/12)
function scoreSolunar(solunar, currentHour) {
  let periodBonus = 0;
  for (const p of solunar.periods) {
    if (isInPeriod(currentHour, p.hour, p.duration)) {
      periodBonus = p.type === 'major' ? 12 : 8;
      break;
    }
    const dist = Math.min(
      Math.abs(currentHour - p.hour),
      Math.abs(currentHour - p.hour + 24),
      Math.abs(currentHour - p.hour - 24)
    );
    if (dist <= 0.5) {
      periodBonus = Math.max(periodBonus, p.type === 'major' ? 10 : 6);
    }
  }

  if (periodBonus > 0) {
    if (solunar.moon.isFullMoon || solunar.moon.isNewMoon) {
      periodBonus = Math.min(12, periodBonus + 3);
    }
    return periodBonus;
  }

  const baseScore = Math.round(solunar.strength * 8);
  if (solunar.moon.isFullMoon || solunar.moon.isNewMoon) {
    return Math.min(12, baseScore + 3);
  }
  return Math.max(3, baseScore);
}

// Factor 5: Tidal Flow (/12)
function scoreTide(tideData, moonPhase) {
  if (!tideData) return 6;

  let score = 6;
  if (tideData.isRising) {
    if (tideData.hoursToNext <= 2) score = 12;
    else if (tideData.hoursToNext <= 4) score = 10;
    else score = 8;
  } else {
    if (tideData.hoursToNext <= 1) score = 9;
    else if (tideData.hoursToNext <= 3) score = 7;
    else score = 6;
  }

  if (tideData.isHigh && tideData.hoursToNext < 0.3) score = 6;
  if (tideData.isLow && tideData.hoursToNext < 0.3) score = 3;

  if (moonPhase.isFullMoon || moonPhase.isNewMoon) {
    score = Math.min(12, score + 2);
  }

  return score;
}

// Factor 6: Water Temperature (/10)
function scoreWaterTemp(tempF) {
  if (tempF >= 74 && tempF <= 80) return 10;
  if (tempF >= 80 && tempF <= 84) return 8;
  if (tempF >= 70 && tempF < 74) return 7;
  if (tempF >= 84 && tempF <= 88) return 5;
  if (tempF < 70) return 3;
  if (tempF > 88) return 2;
  return 5;
}

// Factor 7: Cloud Cover (/8)
function scoreCloudCover(cloudPct) {
  if (cloudPct >= 60 && cloudPct <= 90) return 8;
  if (cloudPct >= 40 && cloudPct < 60) return 7;
  if (cloudPct >= 90) return 6;
  if (cloudPct >= 20 && cloudPct < 40) return 5;
  return 3;
}

// Factor 8: Seasonal Fish Activity (/8)
function scoreSeason() {
  const key = getCurrentSeason();
  const s = seasons[key];
  const hotCount = s.fish.filter(f => f.hot).length;
  const inSeasonCount = s.fish.length;
  const score = hotCount * 2 + (inSeasonCount - hotCount) * 0.5;
  return Math.min(8, Math.round(score));
}

// Factor 9: Dawn/Dusk Proximity (/5)
function scoreDawnDusk(currentHour, sunrise, sunset) {
  const distSunrise = Math.abs(currentHour - sunrise);
  const distSunset = Math.abs(currentHour - sunset);
  const minDist = Math.min(distSunrise, distSunset);

  if (minDist <= 1) return 5;
  if (minDist <= 2) return 4;
  if (minDist <= 3) return 3;
  if (currentHour >= 10 && currentHour <= 14) return 1;
  return 2;
}

// Factor 10: Precipitation Risk (/5)
function scorePrecip(precipProb) {
  if (precipProb <= 10) return 5;
  if (precipProb <= 30) return 4;
  if (precipProb <= 50) return 3;
  if (precipProb <= 70) return 2;
  return 0;
}

// ===============================================
// SPECIES ALERT (water temp)
// ===============================================
const speciesTempRanges = {
  "Sailfish": [72, 82],
  "Mahi-Mahi": [76, 82],
  "Wahoo": [70, 80],
  "Blackfin Tuna": [72, 80],
  "Kingfish": [68, 76],
  "Grouper": [72, 85],
  "Snapper": [70, 85],
  "Tarpon": [75, 90],
  "Snook": [70, 82]
};

function getActiveSpecies(tempF) {
  const active = [];
  for (const [species, range] of Object.entries(speciesTempRanges)) {
    if (tempF >= range[0] && tempF <= range[1]) {
      active.push(species);
    }
  }
  return active;
}

// ===============================================
// CALCULATE & UPDATE PRIME SCORE
// ===============================================
let primeScoreData = {};

function calculatePrimeScore(data) {
  const now = new Date();
  const currentHour = now.getHours() + now.getMinutes() / 60;

  const waveFeet = (data.marine?.current?.wave_height ?? 0) * 3.281;
  const windSpeed = data.weather?.current?.wind_speed_10m ?? 0;
  const windDir = data.weather?.current?.wind_direction_10m ?? 0;
  const pressure = data.weather?.current?.pressure_msl ?? 1013;
  const hourlyPressure = data.weather?.hourly?.pressure_msl ?? [];
  const cloudCover = data.weather?.current?.cloud_cover ?? 50;
  const precipProb = data.weather?.hourly?.precipitation_probability?.[0] ?? 0;
  const waterTemp = data.waterTemp ?? 75;
  const sunrise = data.sunrise ?? 6.5;
  const sunset = data.sunset ?? 18.5;
  const tideData = data.tideData ?? null;
  const solunar = getSolunarTimes(now);
  const moonPhase = solunar.moon;

  const s1 = scoreWaveHeight(waveFeet);
  const s2 = scoreWind(windSpeed, windDir);
  const s3 = scorePressureTrend(pressure, hourlyPressure);
  const s4 = scoreSolunar(solunar, currentHour);
  const s5 = scoreTide(tideData, moonPhase);
  const s6 = scoreWaterTemp(waterTemp);
  const s7 = scoreCloudCover(cloudCover);
  const s8 = scoreSeason();
  const s9 = scoreDawnDusk(currentHour, sunrise, sunset);
  const s10 = scorePrecip(precipProb);

  const total = s1 + s2 + s3 + s4 + s5 + s6 + s7 + s8 + s9 + s10;

  primeScoreData = {
    total,
    scores: [s1, s2, s3, s4, s5, s6, s7, s8, s9, s10],
    maxScores: [12, 14, 14, 12, 12, 10, 8, 8, 5, 5],
    solunar,
    waterTemp,
    sunrise,
    sunset,
    currentHour
  };

  updatePrimeScoreUI();
}

function updatePrimeScoreUI() {
  const { total, scores, maxScores, solunar, waterTemp, sunrise, sunset, currentHour } = primeScoreData;

  const pct = Math.round((total / 100) * 100);
  document.getElementById('primeRing').style.setProperty('--score-pct', pct + '%');
  document.getElementById('primeNum').textContent = total;

  const card = document.getElementById('primeCard');
  const title = document.getElementById('primeTitle');
  const subtitle = document.getElementById('primeSubtitle');

  if (total >= 90) {
    card.className = 'prime-card legendary';
    title.textContent = '🔥 Legendary Conditions';
    subtitle.textContent = 'All factors aligned — exceptional fishing opportunity';
  } else if (total >= 75) {
    card.className = 'prime-card prime-day';
    title.textContent = '⭐ Prime Conditions Detected';
    subtitle.textContent = 'Excellent conditions across multiple factors';
  } else if (total >= 60) {
    card.className = 'prime-card solid';
    title.textContent = '👍 Favorable Conditions';
    subtitle.textContent = 'Solid setup — target optimal feeding windows';
  } else if (total >= 40) {
    card.className = 'prime-card average';
    title.textContent = '🤷 Mixed Conditions';
    subtitle.textContent = 'Moderate setup — fish peak solunar periods';
  } else {
    card.className = 'prime-card wait';
    title.textContent = '⏳ Suboptimal Conditions';
    subtitle.textContent = "Monitor forecast for improvement";
  }

  const factorNames = ['pf1', 'pf2', 'pf3', 'pf4', 'pf5', 'pf6', 'pf7', 'pf8', 'pf9', 'pf10'];
  for (let i = 0; i < 10; i++) {
    const el = document.getElementById(factorNames[i]);
    const bar = document.getElementById(factorNames[i] + 'bar');
    el.textContent = scores[i] + '/' + maxScores[i];
    const pct = Math.round((scores[i] / maxScores[i]) * 100);
    bar.style.width = pct + '%';
    bar.className = 'prime-factor-fill ' + (pct >= 70 ? 'good' : pct >= 40 ? 'ok' : 'poor');
  }

  const timesEl = document.getElementById('solunarTimes');
  timesEl.innerHTML = solunar.periods.map(p => {
    const startH = ((p.hour - p.duration / 2) % 24 + 24) % 24;
    const endH = ((p.hour + p.duration / 2) % 24 + 24) % 24;
    const isActive = isInPeriod(currentHour, p.hour, p.duration);
    const cls = p.type + (isActive ? ' active' : '');
    const nowTag = isActive ? ' <b>ACTIVE</b>' : '';
    return `<div class="solunar-time ${cls}">${p.label} ${formatHour(startH)}–${formatHour(endH)}${nowTag}</div>`;
  }).join('');

  const moonNote = solunar.moon.isFullMoon ? '🌕 Full Moon — peak activity' :
                    solunar.moon.isNewMoon ? '🌑 New Moon — strong pull' :
                    `${solunar.moon.emoji} ${solunar.moon.phaseName} — ${Math.round(solunar.strength * 100)}% strength`;
  timesEl.innerHTML += `<div style="width:100%;text-align:center;font-size:0.72rem;color:var(--text-tertiary);margin-top:6px">${moonNote}</div>`;
  document.getElementById('primeSolunar').style.display = 'block';

  calculateBestTimeToday();

  const activeSpecies = getActiveSpecies(waterTemp);
  const speciesAlert = document.getElementById('speciesAlert');
  const speciesAlertText = document.getElementById('speciesAlertText');
  if (activeSpecies.length > 0) {
    speciesAlertText.innerHTML = `<strong>Water: ${waterTemp.toFixed(1)}°F</strong> — ${activeSpecies.join(', ')} active`;
    speciesAlert.style.display = 'flex';
  } else {
    speciesAlert.style.display = 'none';
  }

  const noaaAlert = document.getElementById('noaaAlert');
  const noaaAlertText = document.getElementById('noaaAlertText');
  const waveFeet = (primeScoreData.waveFeet ?? 0);
  if (waveFeet > 4) {
    noaaAlertText.innerHTML = `<strong>⚠️ Small Craft Advisory</strong> — Waves ${waveFeet.toFixed(1)} ft. Exercise caution.`;
    noaaAlert.style.display = 'flex';
  } else {
    noaaAlert.style.display = 'none';
  }
}

function calculateBestTimeToday() {
  const { solunar, sunrise, sunset } = primeScoreData;
  let bestScore = 0;
  let bestWindow = null;

  for (let h = 0; h < 24; h++) {
    let score = 0;

    for (const p of solunar.periods) {
      if (isInPeriod(h, p.hour, p.duration)) {
        score += p.type === 'major' ? 30 : 15;
      }
    }

    const distSunrise = Math.abs(h - sunrise);
    const distSunset = Math.abs(h - sunset);
    const minDist = Math.min(distSunrise, distSunset);
    if (minDist <= 1) score += 20;
    else if (minDist <= 2) score += 10;

    if (score > bestScore) {
      bestScore = score;
      bestWindow = h;
    }
  }

  if (bestWindow !== null) {
    const startH = Math.max(0, bestWindow - 1);
    const endH = Math.min(23.9, bestWindow + 1);
    document.getElementById('bestTimeText').textContent = `${formatHour(startH)} – ${formatHour(endH)}`;
    document.getElementById('bestTimeBanner').style.display = 'block';
  }
}

// ===============================================
// 7-DAY PRIME SCORE FORECAST
// ===============================================
function build7DayForecast(marine, weather) {
  const grid = document.getElementById('forecastGrid');
  grid.innerHTML = '';

  if (!marine.daily || !marine.daily.time) return;

  const days = marine.daily.time;
  const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  let bestDayIdx = -1;
  let bestDayScore = 0;
  const dayScores = [];

  const hourlyCloud = weather?.hourly?.cloud_cover ?? [];
  const hourlyPressure = weather?.hourly?.pressure_msl ?? [];
  const hourlyPrecip = weather?.hourly?.precipitation_probability ?? [];

  days.forEach((dateStr, i) => {
    const d = new Date(dateStr + 'T12:00:00');
    const maxWaveFt = (marine.daily.wave_height_max[i] ?? 0) * 3.281;

    const waveScore = scoreWaveHeight(maxWaveFt);

    const hourStart = i * 24 + 8;
    const hourEnd = i * 24 + 18;
    let avgCloud = 50;
    if (hourlyCloud.length > hourEnd) {
      const dayCloudSlice = hourlyCloud.slice(hourStart, hourEnd);
      avgCloud = dayCloudSlice.reduce((a, b) => a + b, 0) / dayCloudSlice.length;
    }
    const cloudScore = scoreCloudCover(avgCloud);

    let pressureScore = 10;
    if (hourlyPressure.length > hourEnd) {
      const morningP = hourlyPressure[hourStart] ?? 1013;
      const afternoonP = hourlyPressure[hourStart + 6] ?? 1013;
      const trend = morningP - afternoonP;
      if (trend > 2) pressureScore = 14;
      else if (trend > 1) pressureScore = 12;
      else if (Math.abs(trend) <= 1) pressureScore = 10;
      else if (trend < -2) pressureScore = 3;
      else pressureScore = 6;
    }

    let precipScore = 4;
    if (hourlyPrecip.length > hourEnd) {
      const dayPrecipSlice = hourlyPrecip.slice(hourStart, hourEnd);
      const avgPrecip = dayPrecipSlice.reduce((a, b) => a + b, 0) / dayPrecipSlice.length;
      if (avgPrecip <= 10) precipScore = 5;
      else if (avgPrecip <= 30) precipScore = 4;
      else if (avgPrecip <= 50) precipScore = 3;
      else if (avgPrecip <= 70) precipScore = 2;
      else precipScore = 0;
    }

    const dayMoon = getMoonPhase(d);
    const nearFullOrNew = Math.min(
      Math.abs(dayMoon.age), Math.abs(dayMoon.age - 29.53), Math.abs(dayMoon.age - 14.76)
    );
    const solunarStrength = 1.0 - (nearFullOrNew / 14.76) * 0.5;
    const solunarScore = Math.round(solunarStrength * 12);

    const seasonScore = scoreSeason();
    const baseExtras = 12 + 8 + 3 + 5;

    const dayScore = Math.min(100, waveScore + cloudScore + pressureScore + precipScore + solunarScore + seasonScore + baseExtras);
    dayScores.push(dayScore);

    if (dayScore > bestDayScore) {
      bestDayScore = dayScore;
      bestDayIdx = i;
    }
  });

  days.forEach((dateStr, i) => {
    const d = new Date(dateStr + 'T12:00:00');
    const dayScore = dayScores[i];
    const maxWaveFt = (marine.daily.wave_height_max[i] ?? 0) * 3.281;

    let cls = 'calm', icon = '🎣', scoreClass = 'solid';
    if (dayScore >= 85) { cls = 'calm'; icon = '🔥'; scoreClass = 'legendary'; }
    else if (dayScore >= 70) { cls = 'calm'; icon = '⭐'; scoreClass = 'prime'; }
    else if (dayScore >= 55) { cls = 'moderate'; icon = '👍'; scoreClass = 'solid'; }
    else if (dayScore >= 40) { cls = 'moderate'; icon = '🤷'; scoreClass = 'average'; }
    else { cls = 'rough'; icon = '⏳'; scoreClass = 'wait'; }

    if (maxWaveFt > 4) { cls = 'rough'; icon = '🌊'; scoreClass = 'wait'; }

    const isBest = i === bestDayIdx;

    const c = document.createElement('div');
    c.className = 'forecast-card ' + cls + (isBest ? ' best-day' : '');
    c.innerHTML = `
      <div class="day">${dayNames[d.getDay()]}</div>
      <div class="date">${d.toLocaleDateString('en-US',{month:'short',day:'numeric'})}</div>
      <div class="icon">${icon}</div>
      <div class="prime-mini ${scoreClass}">${Math.round(dayScore)}</div>
      <div class="label">Prime Score</div>
    `;
    grid.appendChild(c);
  });

  document.getElementById('forecastTitle').style.display = 'block';
}

// ===============================================
// TIDE STATUS
// ===============================================
async function fetchTideStatus() {
  let tideData = null;
  try {
    const now = new Date();
    const pad = n => String(n).padStart(2, '0');
    const beginDate = `${now.getFullYear()}${pad(now.getMonth()+1)}${pad(now.getDate())}`;

    const tomorrow = new Date(now);
    tomorrow.setDate(tomorrow.getDate() + 1);
    const endDate = `${tomorrow.getFullYear()}${pad(tomorrow.getMonth()+1)}${pad(tomorrow.getDate())}`;

    const url = `https://api.tidesandcurrents.noaa.gov/api/prod/datagetter?begin_date=${beginDate}&end_date=${endDate}&station=${TIDE_STATION}&product=predictions&datum=MLLW&time_zone=lst_ldt&interval=hilo&units=english&format=json`;

    const res = await fetch(url);
    if (!res.ok) throw new Error('Tide API error');
    const data = await res.json();

    if (!data.predictions || data.predictions.length === 0) throw new Error('No tide data');

    const nowMs = now.getTime();
    let prevTide = null, nextTide = null;

    for (let i = 0; i < data.predictions.length; i++) {
      const t = new Date(data.predictions[i].t.replace(' ', 'T'));
      const tMs = t.getTime();
      if (tMs <= nowMs) {
        prevTide = data.predictions[i];
      } else if (!nextTide) {
        nextTide = data.predictions[i];
        break;
      }
    }

    const tideBox = document.getElementById('tideBox');
    const tideIcon = document.getElementById('tideIcon');
    const tideValue = document.getElementById('tideValue');
    const tideLabel = document.getElementById('tideLabel');

    const tideBanner = document.getElementById('tideBanner');
    const tideBannerEmoji = document.getElementById('tideBannerEmoji');
    const tideBannerStatus = document.getElementById('tideBannerStatus');
    const tideBannerDetail = document.getElementById('tideBannerDetail');

    if (prevTide && nextTide) {
      const prevType = prevTide.type === 'H' ? 'High' : 'Low';
      const nextType = nextTide.type === 'H' ? 'High' : 'Low';
      const nextTime = new Date(nextTide.t.replace(' ', 'T'));
      const hoursUntil = ((nextTime - now) / 3600000);
      const nextTimeStr = nextTime.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });

      let isHighTide = false;
      const isRising = prevTide.type === 'L';
      tideData = { isRising, isHigh: false, isLow: false, hoursToNext: hoursUntil };

      if (prevTide.type === 'H') {
        tideIcon.textContent = '📉';
        tideValue.textContent = 'Falling';
        tideLabel.innerHTML = `After high · Low ${nextTimeStr}`;
      } else {
        tideIcon.textContent = '📈';
        tideValue.textContent = 'Rising';
        tideLabel.innerHTML = `After low · High ${nextTimeStr}`;
        tideBox.classList.add('high-tide');
      }

      if (hoursUntil <= 1) {
        if (nextTide.type === 'H') {
          tideIcon.textContent = '⬆️';
          tideValue.textContent = 'High Tide';
          tideLabel.innerHTML = `Peaks ${nextTimeStr}`;
          tideBox.classList.add('high-tide');
          isHighTide = true;
          tideData.isHigh = true;
        } else {
          tideIcon.textContent = '⬇️';
          tideValue.textContent = 'Low Tide';
          tideData.isLow = true;
          tideLabel.innerHTML = `Low ${nextTimeStr}`;
          tideBox.classList.remove('high-tide');
        }
      }

      if (prevTide.type === 'H') {
        const prevTime = new Date(prevTide.t.replace(' ', 'T'));
        const hoursSincePrev = ((now - prevTime) / 3600000);
        if (hoursSincePrev <= 1.5) {
          isHighTide = true;
        }
      }

      if (isHighTide) {
        tideBanner.className = 'indicator-banner tide-yes';
        tideBannerEmoji.textContent = '🌊';
        tideBannerStatus.innerHTML = '<span class="pulse-dot"></span>High Tide';
        tideBannerDetail.textContent = 'Favorable inshore feeding conditions';
      } else {
        tideBanner.className = 'indicator-banner tide-no';
        tideBannerEmoji.textContent = nextTide.type === 'H' ? '📈' : '📉';
        tideBannerStatus.textContent = isRising ? 'Rising Tide' : 'Falling Tide';
        if (nextTide.type === 'H') {
          tideBannerDetail.textContent = 'Next high tide ' + nextTimeStr + ' (~' + hoursUntil.toFixed(1) + 'h)';
        } else {
          tideBannerDetail.textContent = 'Falling — next high tide later';
        }
      }
    } else {
      tideValue.textContent = 'Check NOAA';
      tideLabel.textContent = 'Data unavailable';
      tideBannerStatus.textContent = 'Unavailable';
      tideBannerDetail.textContent = 'Could not load tide data';
    }
    document.getElementById('indicatorBanners').style.display = 'grid';
  } catch (err) {
    console.error('Tide fetch error:', err);
    document.getElementById('tideValue').textContent = '—';
    document.getElementById('tideLabel').textContent = 'Unavailable';
    document.getElementById('tideBannerStatus').textContent = 'Unavailable';
    document.getElementById('tideBannerDetail').textContent = 'Could not load';
  }

  return tideData;
}

// ===============================================
// MAIN FORECAST FETCH
// ===============================================
async function fetchForecast() {
  const card = document.getElementById('statusCard');
  const emoji = document.getElementById('statusEmoji');
  const title = document.getElementById('statusTitle');
  const subtitle = document.getElementById('statusSubtitle');

  card.className = 'status-card loading';
  emoji.textContent = '🔄';
  title.textContent = 'Analyzing Conditions...';
  subtitle.textContent = 'Evaluating 10 fishing factors...';

  document.getElementById('details').style.display = 'none';
  document.getElementById('detailsRow2').style.display = 'none';
  document.getElementById('forecastTitle').style.display = 'none';
  document.getElementById('forecastGrid').innerHTML = '';
  document.getElementById('tip').style.display = 'none';

  try {
    const [marineRes, weatherRes, waterTempRes] = await Promise.all([
      fetch(MARINE_API),
      fetch(WEATHER_API),
      fetch(WATER_TEMP_API)
    ]);

    if (!marineRes.ok) throw new Error('Marine API error');
    const marine = await marineRes.json();

    let weather = null;
    if (weatherRes.ok) weather = await weatherRes.json();

    let waterTemp = 75;
    if (waterTempRes.ok) {
      const wtData = await waterTempRes.json();
      if (wtData.data && wtData.data.length > 0) {
        waterTemp = parseFloat(wtData.data[0].v);
      }
    }

    const waveFeet = (marine.current?.wave_height ?? 0) * 3.281;
    const currentPeriod = marine.current?.wave_period ?? null;
    const windSpeed = weather?.current?.wind_speed_10m ?? 0;
    const windDir = weather?.current?.wind_direction_10m ?? 0;

    document.getElementById('waveH').textContent = waveFeet.toFixed(1) + ' ft';
    document.getElementById('windS').textContent = Math.round(windSpeed) + ' mph';
    document.getElementById('wavePeriod').textContent = currentPeriod !== null ? currentPeriod.toFixed(0) + 's' : '—';
    document.getElementById('details').style.display = 'grid';
    document.getElementById('detailsRow2').style.display = 'grid';

    updateMoonPhase();

    const tideData = await fetchTideStatus();

    let sunrise = 6.5, sunset = 18.5;
    if (weather && weather.daily && weather.daily.sunrise && weather.daily.sunrise.length > 0) {
      const sr = new Date(weather.daily.sunrise[0]);
      const ss = new Date(weather.daily.sunset[0]);
      sunrise = sr.getHours() + sr.getMinutes() / 60;
      sunset = ss.getHours() + ss.getMinutes() / 60;
    }

    const primeData = {
      marine,
      weather,
      waterTemp,
      tideData,
      sunrise,
      sunset,
      waveFeet
    };

    calculatePrimeScore(primeData);

    build7DayForecast(marine, weather);

    const total = primeScoreData.total;
    if (total >= 90) {
      card.className = 'status-card go';
      emoji.textContent = '🔥';
      title.textContent = 'Legendary Conditions';
      subtitle.textContent = `Prime Score: ${total}/100 — Exceptional fishing opportunity`;
    } else if (total >= 75) {
      card.className = 'status-card go';
      emoji.textContent = '⭐';
      title.textContent = 'Prime Conditions Detected';
      subtitle.textContent = `Prime Score: ${total}/100 — Excellent setup`;
    } else if (total >= 60) {
      card.className = 'status-card maybe';
      emoji.textContent = '👍';
      title.textContent = 'Favorable Conditions';
      subtitle.textContent = `Prime Score: ${total}/100 — Solid opportunity`;
    } else if (total >= 40) {
      card.className = 'status-card maybe';
      emoji.textContent = '🤔';
      title.textContent = 'Mixed Conditions';
      subtitle.textContent = `Prime Score: ${total}/100 — Target peak windows`;
    } else {
      card.className = 'status-card nogo';
      emoji.textContent = '⏳';
      title.textContent = 'Suboptimal Conditions';
      subtitle.textContent = `Prime Score: ${total}/100 — Monitor for improvement`;
    }

    document.getElementById('tipText').textContent = tips[Math.floor(Math.random() * tips.length)];
    document.getElementById('tip').style.display = 'block';

  } catch (err) {
    card.className = 'status-card nogo';
    emoji.textContent = '😕';
    title.textContent = 'Error';
    subtitle.textContent = "Could not load conditions. Try again shortly.";
    console.error(err);
  }
}

