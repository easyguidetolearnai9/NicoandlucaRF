<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nico & Luca RF — Prime Fishing Conditions</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@500;600;700;800;900&display=swap');
  
  :root {
    --bg-primary: #0B1120;
    --bg-secondary: #111827;
    --bg-card: #1A2332;
    --bg-card-hover: #1F2B3D;
    --border: rgba(255,255,255,0.06);
    --border-highlight: rgba(255,255,255,0.12);
    --text-primary: #F1F5F9;
    --text-secondary: #94A3B8;
    --text-tertiary: #64748B;
    --accent-primary: #06B6D4;
    --accent-secondary: #0EA5E9;
    --accent-gold: #F59E0B;
    --accent-green: #10B981;
    --accent-red: #EF4444;
    --accent-yellow: #EAB308;
  }
  
  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg-primary);
    min-height: 100vh;
    color: var(--text-primary);
    overflow-x: hidden;
    font-feature-settings: 'tnum';
  }
  
  /* Ocean background - simplified */
  .ocean-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  }
  
  .wave-decoration {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 200%;
    height: 120px;
    z-index: 0;
    pointer-events: none;
    opacity: 0.05;
  }
  
  .wave-decoration svg { width: 100%; height: 100%; }
  
  .wave1 { animation: drift 8s ease-in-out infinite; }
  .wave2 { animation: drift 11s ease-in-out infinite reverse; bottom: -10px; }
  
  @keyframes drift {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(-5%); }
  }
  
  .container {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 16px 100px;
  }
  
  /* Header */
  .header {
    text-align: center;
    padding: 24px 0 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 24px;
    background: rgba(255,255,255,0.02);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .header .fish-icon {
    font-size: 28px;
    display: inline-block;
    margin-bottom: 4px;
  }
  
  .header h1 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  
  .header p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-weight: 500;
  }
  
  /* Status card - now minimal, Prime card is the hero */
  .status-card {
    border-radius: 12px;
    padding: 16px 20px;
    text-align: center;
    margin-bottom: 16px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  
  .status-card.go { background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(16,185,129,0.05)); border-color: rgba(16,185,129,0.3); }
  .status-card.maybe { background: linear-gradient(135deg, rgba(234,179,8,0.15), rgba(234,179,8,0.05)); border-color: rgba(234,179,8,0.3); }
  .status-card.nogo { background: linear-gradient(135deg, rgba(239,68,68,0.15), rgba(239,68,68,0.05)); border-color: rgba(239,68,68,0.3); }
  .status-card.loading { background: var(--bg-card); }
  
  .status-emoji { font-size: 32px; margin-bottom: 8px; display: inline-block; }
  .status-title { font-family: 'Outfit', sans-serif; font-size: 1.15rem; font-weight: 700; margin-bottom: 4px; }
  .status-subtitle { font-size: 0.875rem; color: var(--text-secondary); line-height: 1.4; }
  
  /* Section titles */
  .section-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 28px 0 14px;
    letter-spacing: -0.01em;
  }
  
  /* Prime card - THE HERO */
  .prime-card {
    border-radius: 16px;
    padding: 28px 24px;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border-highlight);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }
  
  .prime-card.legendary { background: linear-gradient(135deg, rgba(16,185,129,0.2), rgba(16,185,129,0.05)); border-color: var(--accent-green); }
  .prime-card.prime-day { background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(16,185,129,0.03)); border-color: var(--accent-green); }
  .prime-card.solid { background: linear-gradient(135deg, rgba(234,179,8,0.15), rgba(234,179,8,0.03)); border-color: var(--accent-yellow); }
  .prime-card.average { background: linear-gradient(135deg, rgba(245,158,11,0.1), rgba(245,158,11,0.02)); border-color: rgba(245,158,11,0.3); }
  .prime-card.wait { background: linear-gradient(135deg, rgba(239,68,68,0.15), rgba(239,68,68,0.03)); border-color: var(--accent-red); }
  .prime-card.loading { background: var(--bg-card); }
  
  .prime-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 16px;
  }
  
  .prime-score-ring {
    width: 110px;
    height: 110px;
    border-radius: 50%;
    background: conic-gradient(var(--accent-gold) var(--score-pct), rgba(255,255,255,0.08) var(--score-pct));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
  }
  
  .prime-card.legendary .prime-score-ring,
  .prime-card.prime-day .prime-score-ring {
    background: conic-gradient(var(--accent-green) var(--score-pct), rgba(255,255,255,0.08) var(--score-pct));
  }
  
  .prime-card.wait .prime-score-ring {
    background: conic-gradient(var(--accent-red) var(--score-pct), rgba(255,255,255,0.08) var(--score-pct));
  }
  
  .prime-score-inner {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }
  
  .prime-score-num {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1;
    color: var(--accent-gold);
  }
  
  .prime-card.legendary .prime-score-num,
  .prime-card.prime-day .prime-score-num {
    color: var(--accent-green);
  }
  
  .prime-card.wait .prime-score-num {
    color: var(--accent-red);
  }
  
  .prime-score-of {
    font-size: 0.7rem;
    color: var(--text-tertiary);
    font-weight: 600;
  }
  
  .prime-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    text-align: center;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  
  .prime-subtitle {
    font-size: 0.875rem;
    text-align: center;
    color: var(--text-secondary);
    margin-top: 4px;
    line-height: 1.4;
  }
  
  /* Best time banner */
  .best-time-banner {
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(245,158,11,0.3);
    border-radius: 12px;
    padding: 12px 16px;
    margin: 14px 0;
    text-align: center;
  }
  
  .best-time-banner .btt-label {
    font-size: 0.75rem;
    color: var(--accent-gold);
    font-weight: 700;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .best-time-banner .btt-time {
    font-family: 'Outfit', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  
  /* Species alert */
  .species-alert {
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(16,185,129,0.3);
    border-radius: 12px;
    padding: 12px 16px;
    margin: 14px 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .species-alert .sa-icon { font-size: 28px; flex-shrink: 0; }
  .species-alert .sa-text { font-size: 0.875rem; line-height: 1.4; color: var(--text-secondary); }
  .species-alert .sa-text strong { color: var(--accent-green); font-weight: 700; }
  
  /* NOAA alert */
  .noaa-alert {
    background: linear-gradient(135deg, rgba(239,68,68,0.2), rgba(239,68,68,0.05));
    border: 1px solid var(--accent-red);
    border-radius: 12px;
    padding: 12px 16px;
    margin: 14px 0;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .noaa-alert .na-icon { font-size: 28px; flex-shrink: 0; }
  .noaa-alert .na-text { font-size: 0.875rem; line-height: 1.4; color: var(--text-primary); }
  .noaa-alert .na-text strong { font-weight: 700; }
  
  /* Prime factors grid - KEPT HIDDEN (proprietary) */
  .prime-factors { display: none !important; }
  
  /* Solunar feeding windows */
  .prime-solunar {
    margin-top: 16px;
    background: rgba(0,0,0,0.15);
    border-radius: 12px;
    padding: 14px 16px;
    border: 1px solid var(--border);
  }
  
  .prime-solunar-title {
    font-family: 'Outfit', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent-gold);
    margin-bottom: 10px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .solunar-times {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
  }
  
  .solunar-time {
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 0.75rem;
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 500;
  }
  
  .solunar-time.major {
    border-color: rgba(245,158,11,0.4);
    background: rgba(245,158,11,0.1);
    color: var(--accent-gold);
    font-weight: 600;
  }
  
  .solunar-time.minor { color: var(--text-secondary); }
  
  .solunar-time.active {
    animation: pulse-solunar 1.5s ease-in-out infinite;
  }
  
  @keyframes pulse-solunar {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245,158,11,0.3); }
    50% { box-shadow: 0 0 12px 4px rgba(245,158,11,0.2); }
  }
  
  /* Details strip */
  .details {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin-top: 20px;
  }
  
  .details-row2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 10px;
  }
  
  .detail-box {
    background: var(--bg-card);
    border-radius: 12px;
    padding: 14px 10px;
    text-align: center;
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  
  .detail-box:hover { background: var(--bg-card-hover); }
  
  .detail-box .d-icon { font-size: 24px; }
  .detail-box .d-value {
    font-family: 'Outfit', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    margin: 4px 0 2px;
    font-feature-settings: 'tnum';
  }
  .detail-box .d-label { font-size: 0.7rem; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.05em; }
  
  .detail-box.full-moon { border-color: rgba(245,158,11,0.3); background: rgba(245,158,11,0.08); }
  .detail-box.high-tide { border-color: rgba(16,185,129,0.3); background: rgba(16,185,129,0.08); }
  
  /* Indicator banners */
  .indicator-banners {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 16px;
  }
  
  .indicator-banner {
    border-radius: 12px;
    padding: 16px 14px;
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    transition: transform 0.2s;
    border: 1px solid var(--border);
  }
  
  .indicator-banner:hover { transform: translateY(-2px); }
  
  .indicator-banner .ind-emoji { font-size: 36px; margin-bottom: 6px; display: block; }
  .indicator-banner .ind-status {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .indicator-banner .ind-detail { font-size: 0.75rem; color: var(--text-secondary); line-height: 1.3; }
  
  .indicator-banner.moon-yes { background: linear-gradient(135deg, rgba(245,158,11,0.2), rgba(245,158,11,0.05)); border-color: var(--accent-gold); }
  .indicator-banner.moon-yes .ind-status { color: var(--accent-gold); }
  
  .indicator-banner.moon-no { background: var(--bg-card); }
  .indicator-banner.moon-no .ind-status { color: var(--text-secondary); }
  
  .indicator-banner.tide-yes { background: linear-gradient(135deg, rgba(16,185,129,0.2), rgba(16,185,129,0.05)); border-color: var(--accent-green); }
  .indicator-banner.tide-yes .ind-status { color: var(--accent-green); }
  
  .indicator-banner.tide-no { background: var(--bg-card); }
  .indicator-banner.tide-no .ind-status { color: var(--text-secondary); }
  
  .indicator-banner .pulse-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 6px;
    animation: pulse-glow 1.5s ease-in-out infinite;
  }
  
  .indicator-banner.moon-yes .pulse-dot { background: var(--accent-gold); box-shadow: 0 0 8px var(--accent-gold); }
  .indicator-banner.tide-yes .pulse-dot { background: var(--accent-green); box-shadow: 0 0 8px var(--accent-green); }
  
  @keyframes pulse-glow {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }
  
  /* 7-day forecast - horizontal scroll */
  .forecast-grid {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 10px;
    margin-top: 14px;
  }
  
  .forecast-grid::-webkit-scrollbar { height: 6px; }
  .forecast-grid::-webkit-scrollbar-track { background: rgba(255,255,255,0.05); border-radius: 3px; }
  .forecast-grid::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 3px; }
  
  .forecast-card {
    min-width: 140px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 12px;
    text-align: center;
    transition: all 0.2s;
    scroll-snap-align: start;
    flex-shrink: 0;
  }
  
  .forecast-card:hover {
    transform: translateY(-3px);
    background: var(--bg-card-hover);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }
  
  .forecast-card.best-day {
    border: 2px solid var(--accent-gold);
    box-shadow: 0 0 20px rgba(245,158,11,0.3);
    background: rgba(245,158,11,0.08);
  }
  
  .forecast-card .day {
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .forecast-card .date {
    font-size: 0.7rem;
    color: var(--text-tertiary);
    margin-bottom: 8px;
  }
  
  .forecast-card .icon { font-size: 28px; margin: 6px 0; }
  
  .forecast-card .prime-mini {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    margin: 6px 0 2px;
  }
  
  .forecast-card .prime-mini.legendary { color: var(--accent-green); }
  .forecast-card .prime-mini.prime { color: var(--accent-gold); }
  .forecast-card .prime-mini.solid { color: var(--accent-yellow); }
  .forecast-card .prime-mini.average { color: var(--text-secondary); }
  .forecast-card .prime-mini.wait { color: var(--accent-red); }
  
  .forecast-card .label {
    font-size: 0.7rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  /* Fish seasons */
  .season-section { margin-top: 32px; }
  
  .current-season-card {
    border-radius: 16px;
    padding: 22px 18px;
    margin-bottom: 18px;
    border: 1px solid var(--border-highlight);
    box-shadow: 0 6px 24px rgba(0,0,0,0.2);
    background: var(--bg-card);
  }
  
  .season-winter { background: linear-gradient(135deg, rgba(36,116,163,0.15), rgba(36,116,163,0.03)); }
  .season-spring { background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(16,185,129,0.03)); }
  .season-summer { background: linear-gradient(135deg, rgba(245,158,11,0.15), rgba(245,158,11,0.03)); }
  .season-fall { background: linear-gradient(135deg, rgba(211,84,0,0.15), rgba(211,84,0,0.03)); }
  
  .season-badge {
    display: inline-block;
    background: rgba(0,0,0,0.3);
    border-radius: 20px;
    padding: 4px 14px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.7rem;
    color: var(--accent-gold);
    margin-bottom: 12px;
    letter-spacing: 0.05em;
    font-weight: 700;
    text-transform: uppercase;
  }
  
  .season-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  
  .season-header .season-icon { font-size: 32px; }
  .season-header .season-name {
    font-family: 'Outfit', sans-serif;
    font-size: 1.375rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  
  .season-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 16px;
    text-align: center;
  }
  
  /* Fish cards */
  .fish-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  
  .fish-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 12px;
    text-align: center;
    transition: all 0.2s;
    cursor: pointer;
  }
  
  .fish-card:hover {
    transform: translateY(-3px);
    background: var(--bg-card-hover);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }
  
  .fish-card.hot { border-color: rgba(245,158,11,0.3); background: rgba(245,158,11,0.05); }
  
  .fish-card .fish-img {
    width: 90px;
    height: 56px;
    margin: 0 auto 8px;
    display: block;
    object-fit: contain;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4));
  }
  
  .fish-card .fish-name {
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  
  .fish-card.hot .fish-name { color: var(--accent-gold); }
  
  .fish-card .fish-months {
    font-size: 0.7rem;
    color: var(--text-tertiary);
    line-height: 1.3;
  }
  
  .fish-card .hot-badge {
    display: inline-block;
    background: var(--accent-red);
    color: #fff;
    font-size: 0.6rem;
    font-weight: 800;
    padding: 2px 8px;
    border-radius: 8px;
    margin-top: 6px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  
  .fish-card .tap-hint { display: none; }
  
  /* Fish modal */
  .fish-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.75);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    padding: 16px;
    backdrop-filter: blur(4px);
  }
  
  .fish-modal-overlay.open { display: flex; }
  
  .fish-modal {
    background: var(--bg-secondary);
    border: 1px solid var(--border-highlight);
    border-radius: 16px;
    max-width: 440px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    padding: 24px 20px;
    position: relative;
    box-shadow: 0 12px 48px rgba(0,0,0,0.5);
  }
  
  .fish-modal .close-btn {
    position: absolute;
    top: 12px;
    right: 14px;
    font-size: 1.5rem;
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  
  .fish-modal .close-btn:hover { opacity: 1; }
  
  .fish-modal .fm-img {
    width: 140px;
    height: 88px;
    margin: 0 auto 10px;
    display: block;
    object-fit: contain;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.5));
  }
  
  .fish-modal .fm-name {
    font-family: 'Outfit', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    text-align: center;
    margin-bottom: 6px;
  }
  
  .fish-modal .fm-season {
    text-align: center;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 18px;
  }
  
  .fish-modal .fm-section { margin-bottom: 14px; }
  
  .fish-modal .fm-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent-gold);
    margin-bottom: 6px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .fish-modal .fm-text {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }
  
  .fish-modal .fm-speed {
    display: inline-block;
    background: rgba(255,255,255,0.08);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 8px 16px;
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--accent-green);
    margin-top: 6px;
  }
  
  /* Season tabs */
  .season-tabs {
    display: flex;
    gap: 6px;
    justify-content: center;
    margin: 18px 0 14px;
    flex-wrap: wrap;
  }
  
  .season-tab {
    padding: 8px 16px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    font-family: 'Outfit', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .season-tab:hover { background: var(--bg-card-hover); }
  .season-tab.active {
    background: rgba(245,158,11,0.15);
    color: var(--accent-gold);
    border-color: var(--accent-gold);
  }
  
  .season-panel { display: none; }
  .season-panel.active { display: block; }
  
  .season-panel-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px 16px;
    margin-bottom: 10px;
  }
  
  .season-panel-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  /* Charter marketplace */
  .charter-section { margin-top: 40px; }
  
  .charter-tabs {
    display: flex;
    gap: 6px;
    justify-content: center;
    margin: 14px 0;
    flex-wrap: wrap;
  }
  
  .charter-tab {
    padding: 8px 18px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    font-family: 'Outfit', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .charter-tab:hover { background: var(--bg-card-hover); }
  .charter-tab.active {
    background: rgba(6,182,212,0.15);
    color: var(--accent-primary);
    border-color: var(--accent-primary);
  }
  
  .charter-panel { display: none; }
  .charter-panel.active { display: block; }
  
  /* Catch feed */
  .catch-feed {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  
  .catch-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    transition: all 0.2s;
  }
  
  .catch-card:hover {
    transform: translateY(-2px);
    background: var(--bg-card-hover);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }
  
  .catch-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  
  .catch-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }
  
  .catch-charter-name {
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
  }
  
  .catch-boat { font-size: 0.7rem; color: var(--text-tertiary); }
  .catch-time { font-size: 0.68rem; color: var(--text-tertiary); margin-left: auto; }
  
  .catch-img {
    width: 100%;
    max-height: 240px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 10px;
    cursor: pointer;
  }
  
  .catch-details {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  
  .catch-tag {
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 4px 10px;
    font-size: 0.75rem;
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 500;
  }
  
  .catch-tag .tag-icon { font-size: 0.9rem; }
  .catch-note {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }
  
  .reserve-btn {
    display: inline-block;
    margin-top: 10px;
    padding: 10px 24px;
    background: linear-gradient(135deg, var(--accent-green), rgba(16,185,129,0.8));
    color: #fff;
    border: none;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }
  
  .reserve-btn:hover {
    transform: scale(1.04);
    box-shadow: 0 4px 16px rgba(16,185,129,0.3);
  }
  
  /* Charter profiles */
  .charter-profile {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 18px;
    margin-bottom: 14px;
    transition: all 0.2s;
  }
  
  .charter-profile:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }
  
  .charter-profile-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }
  
  .charter-profile-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-gold), rgba(245,158,11,0.8));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    flex-shrink: 0;
  }
  
  .charter-profile-name {
    font-family: 'Outfit', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
  }
  
  .charter-profile-boat { font-size: 0.8rem; color: var(--text-secondary); }
  
  .charter-profile-stats {
    display: flex;
    gap: 16px;
    margin: 12px 0;
    flex-wrap: wrap;
  }
  
  .charter-stat { text-align: center; }
  .charter-stat-val {
    font-family: 'Outfit', sans-serif;
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--accent-gold);
  }
  .charter-stat-label { font-size: 0.68rem; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.05em; }
  
  .charter-profile-contact { font-size: 0.82rem; color: var(--text-secondary); margin-top: 8px; }
  .charter-profile-contact a { color: var(--accent-green); text-decoration: none; }
  
  /* Forms */
  .charter-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 16px;
  }
  
  .charter-form h3 {
    font-family: 'Outfit', sans-serif;
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--accent-gold);
    margin-bottom: 16px;
    text-align: center;
  }
  
  .form-group { margin-bottom: 12px; }
  .form-group label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 6px;
    font-weight: 600;
  }
  
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.04);
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: all 0.2s;
  }
  
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--accent-gold);
    background: rgba(255,255,255,0.06);
  }
  
  .form-group select option { background: var(--bg-secondary); color: var(--text-primary); }
  .form-group textarea { resize: vertical; min-height: 60px; }
  
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  
  .submit-btn {
    display: block;
    width: 100%;
    padding: 12px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    color: #fff;
    border: none;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    margin-top: 8px;
  }
  
  .submit-btn:hover {
    transform: scale(1.02);
    box-shadow: 0 4px 16px rgba(6,182,212,0.3);
  }
  
  .submit-btn.danger {
    background: linear-gradient(135deg, var(--accent-red), rgba(239,68,68,0.8));
  }
  
  .submit-btn.danger:hover {
    box-shadow: 0 4px 16px rgba(239,68,68,0.3);
  }
  
  .submit-btn.success {
    background: linear-gradient(135deg, var(--accent-green), rgba(16,185,129,0.8));
  }
  
  .submit-btn.success:hover {
    box-shadow: 0 4px 16px rgba(16,185,129,0.3);
  }
  
  .empty-state {
    text-align: center;
    padding: 40px 16px;
    color: var(--text-tertiary);
    font-size: 0.9rem;
  }
  
  .empty-state .empty-icon { font-size: 48px; margin-bottom: 12px; opacity: 0.5; }
  
  /* Image preview */
  .img-preview-wrap { position: relative; display: inline-block; margin-top: 8px; }
  .img-preview { max-width: 100%; max-height: 160px; border-radius: 12px; object-fit: cover; }
  .img-remove {
    position: absolute;
    top: 6px;
    right: 6px;
    background: rgba(0,0,0,0.7);
    color: #fff;
    border: none;
    border-radius: 50%;
    width: 26px;
    height: 26px;
    cursor: pointer;
    font-size: 16px;
    line-height: 26px;
    text-align: center;
  }
  
  /* Lightbox */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.9);
    z-index: 2000;
    justify-content: center;
    align-items: center;
    padding: 20px;
    backdrop-filter: blur(6px);
  }
  
  .lightbox.open { display: flex; }
  .lightbox img { max-width: 95%; max-height: 90vh; border-radius: 12px; object-fit: contain; }
  .lightbox .close-btn {
    position: absolute;
    top: 16px;
    right: 20px;
    font-size: 2rem;
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
  }
  
  /* Fish toggle */
  .fish-toggle {
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
    user-select: none;
    padding: 6px 0;
  }
  
  .fish-toggle-track {
    width: 56px;
    height: 30px;
    border-radius: 15px;
    background: rgba(255,255,255,0.1);
    border: 2px solid var(--border);
    position: relative;
    transition: all 0.3s;
  }
  
  .fish-toggle-track.on {
    background: linear-gradient(135deg, var(--accent-green), rgba(16,185,129,0.8));
    border-color: var(--accent-green);
  }
  
  .fish-toggle-thumb {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #fff;
    position: absolute;
    top: 1px;
    left: 2px;
    transition: transform 0.3s;
    box-shadow: 0 2px 6px rgba(0,0,0,0.3);
  }
  
  .fish-toggle-track.on .fish-toggle-thumb { transform: translateX(26px); }
  
  .fish-toggle-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    transition: color 0.3s;
  }
  
  .fish-toggle-label.on { color: var(--accent-green); }
  
  .fish-avail-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 14px;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    margin-top: 10px;
  }
  
  .fish-avail-badge.yes {
    background: rgba(16,185,129,0.15);
    border: 1px solid rgba(16,185,129,0.4);
    color: var(--accent-green);
  }
  
  .fish-avail-badge.no {
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--border);
    color: var(--text-tertiary);
  }
  
  /* Tip */
  .tip {
    margin-top: 24px;
    background: rgba(245,158,11,0.08);
    border: 1px solid rgba(245,158,11,0.2);
    border-radius: 12px;
    padding: 14px 18px;
    text-align: center;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  
  .tip strong { color: var(--accent-gold); font-weight: 700; }
  
  /* Footer */
  .footer {
    text-align: center;
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    line-height: 1.7;
  }
  
  .footer strong { color: var(--text-secondary); font-weight: 600; }
  
  .refresh-btn {
    display: block;
    margin: 24px auto 0;
    padding: 12px 32px;
    background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
    color: #fff;
    border: none;
    border-radius: 40px;
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
  }
  
  .refresh-btn:hover {
    transform: scale(1.04);
    box-shadow: 0 4px 16px rgba(6,182,212,0.3);
  }
  
  /* Toast */
  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--accent-green);
    color: #fff;
    padding: 12px 24px;
    border-radius: 12px;
    font-family: 'Outfit', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    z-index: 3000;
    transition: transform 0.3s ease;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }
  
  .toast.show { transform: translateX(-50%) translateY(0); }
  
  /* Mobile optimization */
  @media (max-width: 440px) {
    .header h1 { font-size: 1.5rem; }
    .status-emoji { font-size: 28px; }
    .status-title { font-size: 1rem; }
    .prime-header { flex-direction: column; gap: 12px; }
    .prime-score-ring { width: 100px; height: 100px; }
    .prime-score-inner { width: 80px; height: 80px; }
    .prime-score-num { font-size: 2rem; }
    .fish-grid { grid-template-columns: 1fr 1fr; }
    .forecast-grid { gap: 8px; }
    .form-row { grid-template-columns: 1fr; }
    .details { grid-template-columns: 1fr 1fr 1fr; }
    .indicator-banners { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
<div class="ocean-bg" id="bubbles"></div>
<div class="wave-decoration wave1"><svg viewBox="0 0 1440 120" preserveAspectRatio="none"><path d="M0,40 C360,100 720,0 1080,60 C1260,90 1380,50 1440,40 L1440,120 L0,120Z" fill="#1a5276"/></svg></div>
<div class="wave-decoration wave2"><svg viewBox="0 0 1440 120" preserveAspectRatio="none"><path d="M0,60 C240,10 480,90 720,40 C960,0 1200,80 1440,50 L1440,120 L0,120Z" fill="#0d2137"/></svg></div>

<!-- Fish Detail Modal -->
<div class="fish-modal-overlay" id="fishModal" onclick="if(event.target===this)closeModal()">
  <div class="fish-modal">
    <button class="close-btn" onclick="closeModal()">&times;</button>
    <img class="fm-img" id="fmImg" src="" alt="">
    <div class="fm-name" id="fmName"></div>
    <div class="fm-season" id="fmSeason"></div>
    <div class="fm-section"><div class="fm-label">🎣 Best Bait</div><div class="fm-text" id="fmBait"></div></div>
    <div class="fm-section"><div class="fm-label">🛥️ Technique</div><div class="fm-text" id="fmTechnique"></div></div>
    <div class="fm-section" id="fmSpeedSection"><div class="fm-label">⚡ Boat Speed</div><div class="fm-speed" id="fmSpeed"></div></div>
    <div class="fm-section"><div class="fm-label">🌟 Notes</div><div class="fm-text" id="fmFact"></div></div>
  </div>
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" onclick="closeLightbox()">
  <button class="close-btn">&times;</button>
  <img id="lightboxImg" src="" alt="Catch photo">
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<div class="container">
  <div class="header">
    <div class="fish-icon">🐠</div>
    <h1>Nico & Luca RF</h1>
    <p>Key Biscayne, FL 33149 · Prime Fishing Conditions</p>
  </div>

  <div class="status-card loading" id="statusCard">
    <div class="status-emoji" id="statusEmoji">🔄</div>
    <div class="status-title" id="statusTitle">Analyzing Conditions...</div>
    <div class="status-subtitle" id="statusSubtitle">Evaluating 10 fishing factors...</div>
  </div>

  <!-- PRIME FISHING SCORE -->
  <div class="prime-card loading" id="primeCard">
    <div class="prime-header">
      <div class="prime-score-ring" id="primeRing" style="--score-pct:0%">
        <div class="prime-score-inner">
          <div class="prime-score-num" id="primeNum">—</div>
          <div class="prime-score-of">/100</div>
        </div>
      </div>
      <div>
        <div class="prime-title" id="primeTitle">Calculating Prime Score...</div>
        <div class="prime-subtitle" id="primeSubtitle">Analyzing conditions...</div>
      </div>
    </div>

    <!-- Best Time Today -->
    <div class="best-time-banner" id="bestTimeBanner" style="display:none">
      <div class="btt-label">⏰ Optimal Fishing Window</div>
      <div class="btt-time" id="bestTimeText">—</div>
    </div>

    <!-- Species Alert -->
    <div class="species-alert" id="speciesAlert" style="display:none">
      <div class="sa-icon">🌡️</div>
      <div class="sa-text" id="speciesAlertText">Loading water temp...</div>
    </div>

    <!-- NOAA Alert -->
    <div class="noaa-alert" id="noaaAlert" style="display:none">
      <div class="na-icon">⚠️</div>
      <div class="na-text" id="noaaAlertText">Checking marine forecasts...</div>
    </div>

    <!-- 10-Factor Grid (KEPT HIDDEN) -->
    <div class="prime-factors" id="primeFactors" style="display:none">
      <div class="prime-factor"><div class="prime-factor-icon">🌊</div><div class="prime-factor-name">Wave Height</div><div class="prime-factor-val" id="pf1">—</div><div class="prime-factor-bar"><div class="prime-factor-fill" id="pf1bar"></div></div></div>
      <div class="prime-factor"><div class="prime-factor-icon">💨</div><div class="prime-factor-name">Wind</div><div class="prime-factor-val" id="pf2">—</div><div class="prime-factor-bar"><div class="prime-factor-fill" id="pf2bar"></div></div></div>
      <div class="prime-factor"><div class="prime-factor-icon">📉</div><div class="prime-factor-name">Pressure Trend</div><div class="prime-factor-val" id="pf3">—</div><div class="prime-factor-bar"><div class="prime-factor-fill" id="pf3bar"></div></div></div>
      <div class="prime-factor"><div class="prime-factor-icon">🌙</div><div class="prime-factor-name">Solunar</div><div class="prime-factor-val" id="pf4">—</div><div class="prime-factor-bar"><div class="prime-factor-fill" id="pf4bar"></div></div></div>
      <div class="prime-factor"><div class="prime-factor-icon">🌊</div><div class="prime-factor-name">Tidal Flow</div><div class="prime-factor-val" id="pf5">—</div><div class="prime-factor-bar"><div class="prime-factor-fill" id="pf5bar"></div></div></div>
      <div class="prime-factor"><div class="prime-factor-icon">🌡️</div><div class="prime-factor-name">Water Temp</div><div class="prime-factor-val" id="pf6">—</div><div class="prime-factor-bar"><div class="prime-factor-fill" id="pf6bar"></div></div></div>
      <div class="prime-factor"><div class="prime-factor-icon">☁️</div><div class="prime-factor-name">Cloud Cover</div><div class="prime-factor-val" id="pf7">—</div><div class="prime-factor-bar"><div class="prime-factor-fill" id="pf7bar"></div></div></div>
      <div class="prime-factor"><div class="prime-factor-icon">🐟</div><div class="prime-factor-name">Season</div><div class="prime-factor-val" id="pf8">—</div><div class="prime-factor-bar"><div class="prime-factor-fill" id="pf8bar"></div></div></div>
      <div class="prime-factor"><div class="prime-factor-icon">🌅</div><div class="prime-factor-name">Dawn/Dusk</div><div class="prime-factor-val" id="pf9">—</div><div class="prime-factor-bar"><div class="prime-factor-fill" id="pf9bar"></div></div></div>
      <div class="prime-factor"><div class="prime-factor-icon">🌧️</div><div class="prime-factor-name">Precip Risk</div><div class="prime-factor-val" id="pf10">—</div><div class="prime-factor-bar"><div class="prime-factor-fill" id="pf10bar"></div></div></div>
    </div>

    <!-- Solunar Feeding Windows -->
    <div class="prime-solunar" id="primeSolunar" style="display:none">
      <div class="prime-solunar-title">🕐 Feeding Windows</div>
      <div class="solunar-times" id="solunarTimes"></div>
    </div>
  </div>

  <!-- Wave / Wind / Period -->
  <div class="details" id="details" style="display:none">
    <div class="detail-box"><div class="d-icon">🌊</div><div class="d-value" id="waveH">—</div><div class="d-label">Wave Height</div></div>
    <div class="detail-box"><div class="d-icon">💨</div><div class="d-value" id="windS">—</div><div class="d-label">Wind Speed</div></div>
    <div class="detail-box"><div class="d-icon">⏱️</div><div class="d-value" id="wavePeriod">—</div><div class="d-label">Wave Period</div></div>
  </div>

  <!-- Moon Phase & Tide Status -->
  <div class="details-row2" id="detailsRow2" style="display:none">
    <div class="detail-box" id="moonBox">
      <div class="d-icon" id="moonIcon">🌑</div>
      <div class="d-value" id="moonValue">—</div>
      <div class="d-label" id="moonLabel">Moon Phase</div>
    </div>
    <div class="detail-box" id="tideBox">
      <div class="d-icon" id="tideIcon">🌊</div>
      <div class="d-value" id="tideValue">—</div>
      <div class="d-label" id="tideLabel">Tide Status</div>
    </div>
  </div>

  <!-- Moon & Tide Indicator Banners -->
  <div class="indicator-banners" id="indicatorBanners" style="display:none">
    <div class="indicator-banner moon-no" id="moonBanner">
      <span class="ind-emoji" id="moonBannerEmoji">🌑</span>
      <div class="ind-status" id="moonBannerStatus">Checking...</div>
      <div class="ind-detail" id="moonBannerDetail">Loading moon phase</div>
    </div>
    <div class="indicator-banner tide-no" id="tideBanner">
      <span class="ind-emoji" id="tideBannerEmoji">🌊</span>
      <div class="ind-status" id="tideBannerStatus">Checking...</div>
      <div class="ind-detail" id="tideBannerDetail">Loading tide data</div>
    </div>
  </div>

  <div class="section-title" id="forecastTitle" style="display:none">📅 7-Day Prime Score Forecast</div>
  <div class="forecast-grid" id="forecastGrid"></div>

  <!-- FISHING SEASONS -->
  <div class="season-section">
    <div class="section-title">🐟 In Season Now</div>
    <p style="text-align:center;font-size:0.8rem;color:var(--text-secondary);margin-bottom:14px">Tap any species for bait, technique, and optimal boat speed</p>
    <div class="current-season-card" id="currentSeasonCard">
      <div class="season-badge" id="currentSeasonBadge">LOADING...</div>
      <div class="season-header">
        <span class="season-icon" id="currentSeasonIcon">🔄</span>
        <span class="season-name" id="currentSeasonName">Analyzing...</span>
      </div>
      <div class="season-desc" id="currentSeasonDesc">Loading seasonal fish data...</div>
      <div class="fish-grid" id="currentFishGrid"></div>
    </div>

    <div class="section-title">📆 All Seasons</div>
    <div class="season-tabs">
      <div class="season-tab" data-season="winter" onclick="showSeasonPanel('winter')">❄️ Winter</div>
      <div class="season-tab" data-season="spring" onclick="showSeasonPanel('spring')">🌸 Spring</div>
      <div class="season-tab" data-season="summer" onclick="showSeasonPanel('summer')">☀️ Summer</div>
      <div class="season-tab" data-season="fall" onclick="showSeasonPanel('fall')">🍂 Fall</div>
    </div>
    <div id="seasonPanels"></div>
  </div>

  <!-- CHARTER MARKETPLACE -->
  <div class="charter-section">
    <div class="section-title">🚤 Charter Marketplace</div>
    <p style="text-align:center;font-size:0.8rem;color:var(--text-secondary);margin-bottom:14px">Reserve fresh catch from local charters</p>

    <div class="charter-tabs">
      <div class="charter-tab active" data-ctab="feed" onclick="showCharterTab('feed')">🐟 Available Catch</div>
      <div class="charter-tab" data-ctab="charters" onclick="showCharterTab('charters')">🚤 Charters</div>
      <div class="charter-tab" data-ctab="upload" onclick="showCharterTab('upload')">📸 Post Catch</div>
      <div class="charter-tab" data-ctab="profile" onclick="showCharterTab('profile')">👤 Profile</div>
    </div>

    <div class="charter-panel active" id="panel-feed">
      <div class="catch-feed" id="catchFeed">
        <div class="empty-state">
          <div class="empty-icon">🎣</div>
          <div>No catches posted yet.<br>Charters — post your fresh catch!</div>
        </div>
      </div>
    </div>

    <div class="charter-panel" id="panel-charters">
      <div id="charterDirectory">
        <div class="empty-state">
          <div class="empty-icon">🚤</div>
          <div>No charters registered.<br>Create your profile to get listed.</div>
        </div>
      </div>
    </div>

    <div class="charter-panel" id="panel-upload">
      <div class="charter-form" id="uploadForm">
        <h3>📸 Post Fresh Catch</h3>
        <p style="text-align:center;font-size:0.78rem;color:var(--text-secondary);margin-bottom:14px">List your fresh catch for customer reservations</p>
        <div id="needProfileMsg" style="display:none;text-align:center;padding:16px;color:var(--accent-gold);font-size:0.9rem">
          ⚠️ Create your charter profile first
          <button class="submit-btn" style="margin-top:12px;max-width:200px;margin-left:auto;margin-right:auto" onclick="showCharterTab('profile')">Create Profile</button>
        </div>
        <div id="uploadFields">
          <div class="form-group">
            <label>📷 Photo</label>
            <input type="file" id="catchPhoto" accept="image/*" capture="environment" onchange="previewCatchPhoto(this)">
            <div id="catchPhotoPreview"></div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>🐟 Species</label>
              <select id="catchSpecies">
                <option value="">Select...</option>
                <option value="Sailfish">Sailfish</option>
                <option value="Mahi-Mahi">Mahi-Mahi</option>
                <option value="Wahoo">Wahoo</option>
                <option value="Blackfin Tuna">Blackfin Tuna</option>
                <option value="Kingfish">Kingfish</option>
                <option value="Blue Marlin">Blue Marlin</option>
                <option value="Swordfish">Swordfish</option>
                <option value="Cobia">Cobia</option>
                <option value="Tarpon">Tarpon</option>
                <option value="Grouper">Grouper</option>
                <option value="Snapper">Snapper</option>
                <option value="Snook">Snook</option>
                <option value="Bonefish">Bonefish</option>
                <option value="Permit">Permit</option>
                <option value="Yellowtail Snapper">Yellowtail Snapper</option>
                <option value="Hogfish">Hogfish</option>
                <option value="Tripletail">Tripletail</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label>⚖️ Weight (lbs)</label>
              <input type="number" id="catchWeight" placeholder="e.g. 25" min="0" step="0.1">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>📏 Length (inches)</label>
              <input type="number" id="catchLength" placeholder="e.g. 42" min="0" step="0.5">
            </div>
            <div class="form-group">
              <label>💰 Available?</label>
              <select id="catchAvailable">
                <option value="yes">✅ Yes — Reserve</option>
                <option value="no">❌ Released</option>
                <option value="sold">🔒 Sold</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>💲 Price/lb (optional)</label>
              <input type="number" id="catchPrice" placeholder="e.g. 12.50" min="0" step="0.01">
            </div>
            <div class="form-group">
              <label>📍 Location</label>
              <select id="catchLocation">
                <option value="">Select area...</option>
                <option value="Offshore Key Biscayne">Offshore Key Biscayne</option>
                <option value="Biscayne Bay">Biscayne Bay</option>
                <option value="Government Cut">Government Cut</option>
                <option value="Stiltsville Flats">Stiltsville Flats</option>
                <option value="Bear Cut">Bear Cut</option>
                <option value="Fowey Lighthouse">Fowey Lighthouse</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label>📝 Notes (optional)</label>
            <textarea id="catchNotes" placeholder="Method, freshness, pickup details..."></textarea>
